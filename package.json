{
  "name": "holographic-virtual-librarian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WebXR/MediaPipe facial (and optional body) capture driving a 3D avatar rendered in a 4-viewport Pepper's-Ghost layout for an iPad-mounted hologram pyramid.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:http": "HTTP_ONLY=1 vite",
    "prebuild": "bash scripts/sync-public-assets.sh",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "relay": "node server/relay.js",
    "start": "concurrently \"npm:relay\" \"npm:dev\"",
    "start:http": "concurrently \"npm:relay\" \"npm:dev:http\"",
    "ios:init": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "npm run ios:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^6.0.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@mediapipe/tasks-vision": "^0.10.14",
    "@pixiv/three-vrm": "^3.0.0",
    "three": "^0.160.0",
    "vosk-browser": "^0.0.8",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "concurrently": "^8.2.2",
    "vite": "^5.0.0"
  }
}
